{
  "name": "@frontendnetwork/veganify",
  "version": "2.1.5",
  "description": "A wrapper for the official Veganify API",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/cjs/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/cjs/index.d.ts"
    }
  },
  "files": [
    "dist/cjs",
    "dist/esm"
  ],
  "scripts": {
    "test": "jest",
    "clean": "rimraf dist",
    "check-types": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.esm.json --noEmit",
    "format:check": "prettier --check lib",
    "format": "prettier --write lib",
    "checks": "npm run check-types && npm run lint && npm run test",
    "prebuild": "npm run checks && npm run clean",
    "build:cjs": "tsc -p tsconfig.json",
    "build:esm": "tsc -p tsconfig.esm.json && node scripts/add-esm-extensions.mjs && echo '{\"type\":\"module\"}' > dist/esm/package.json",
    "build": "npm run build:cjs && npm run build:esm",
    "lint": "eslint lib",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/frontendnetwork/veganify-api-wrapper.git"
  },
  "keywords": [
    "API",
    "Vegan",
    "Veganify",
    "React",
    "TypeScript"
  ],
  "author": "FrontEndNet.work, Philip Brembeck",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/frontendnetwork/veganify-api-wrapper/issues"
  },
  "homepage": "https://github.com/frontendnetwork/veganify-api-wrapper#readme",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^24.9.2",
    "@typescript-eslint/eslint-plugin": "^8.12.2",
    "@typescript-eslint/parser": "^8.12.2",
    "eslint": "^9.14.0",
    "jest": "^29.7.0",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.2.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1"
  },
  "dependencies": {
    "zod": "^4.4.2"
  }
}
